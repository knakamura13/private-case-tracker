# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/case_tracker?schema=public"

# --- App ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:3000
PUBLIC_APP_NAME="Private Case Tracker"

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET="change-me-to-a-random-32-byte-base64-string"
BETTER_AUTH_URL=http://localhost:3000
# Whether new account sign-up is allowed without an invitation token.
# Keep false after the first owner has been created.
ALLOW_OPEN_SIGNUP=true

# --- Field-level encryption (AES-256-GCM). 32 random bytes, base64 encoded. ---
FIELD_ENCRYPTION_KEY="base64-32-random-bytes-here=="

# --- Object storage (S3-compatible; Railway Buckets in production) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=case-tracker
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_READ=false

# --- Email (Resend). Leave RESEND_API_KEY unset in dev to use the console stub. ---
RESEND_API_KEY=
EMAIL_FROM="Case Tracker <noreply@example.com>"
