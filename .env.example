APP_URL=http://localhost:5173
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=replace_me_with_32+_random_bytes_base64
FIELD_ENCRYPTION_KEY=replace_me_with_32_random_bytes_base64

# DynamoDB (local default via docker compose)
AWS_REGION=us-east-1
DYNAMO_TABLE=case-tracker-dev
DYNAMO_ENDPOINT=http://localhost:8000

# Optional: local MinIO (file uploads)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=case-tracker
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_FORCE_PATH_STYLE=true

# Optional: dev email (if unset, app logs emails to console)
# RESEND_API_KEY=
# EMAIL_FROM=Case Tracker <noreply@example.com>
